{
    "name": "shopapps/laravel-settings",
    "description": "config style settings but stored in a DB",
    "version": "1.0.27",
    "keywords": [
        "shopapps",
        "laravel-settings"
    ],
    "homepage": "https://github.com/shopapps/laravel-settings",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Paul Robbins",
            "email": "shopappsuk@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3|^8.4",
        "filament/filament": "^3.3.49",
        "laravel/framework": "^10.10",
        "spatie/laravel-package-tools": "^1.0"
    },
    "require-dev": {
        "laravel/pint": "^1.10|^2.0|^3.0",
        "orchestra/testbench": "^8.37|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^9.0|^10.5|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Shopapps\\LaravelSettings\\": "src"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Shopapps\\LaravelSettings\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Shopapps\\LaravelSettings\\LaravelSettingsServiceProvider"
            ],
            "aliases": {
                "LaravelSettings": "Shopapps\\LaravelSettings\\LaravelSettingsFacade"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
